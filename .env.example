# ReClaw Configuration

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/reclaw.db
LANCE_DB_PATH=./data/lance_db
UPLOAD_DIR=./data/uploads
PROJECTS_DIR=./data/projects

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Hardware Resource Budget
# How much RAM (GB) to reserve for OS and other apps
RESOURCE_RESERVE_RAM_GB=4
# What percentage of CPU to reserve (0-100)
RESOURCE_RESERVE_CPU_PERCENT=30

# File Watcher
FILE_WATCH_INTERVAL_SECONDS=5

# RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
