# =============================================================================
# ReClaw Configuration
# Copy to .env and adjust values for your environment
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# "ollama" or "lmstudio"
LLM_PROVIDER=lmstudio

# LM Studio (OpenAI-compatible API — default for local dev)
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_MODEL=default
LMSTUDIO_EMBED_MODEL=default

# Ollama (alternative provider)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Database ----------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/reclaw.db
LANCE_DB_PATH=./data/lance_db
UPLOAD_DIR=./data/uploads
PROJECTS_DIR=./data/projects

# PostgreSQL (team mode only — docker compose --profile team up)
# POSTGRES_USER=reclaw
# POSTGRES_PASSWORD=          # Generate with: ./scripts/generate-secrets.sh
# POSTGRES_DB=reclaw
# DATABASE_URL=postgresql+asyncpg://reclaw:PASSWORD@localhost:5432/reclaw

# --- Security ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=                   # Generate with: ./scripts/generate-secrets.sh (auto-generated if blank)
JWT_EXPIRE_MINUTES=1440
TEAM_MODE=false
RATE_LIMIT_ENABLED=true

# Data encryption key (auto-generated on first startup — DO NOT LOSE THIS KEY)
# If lost, encrypted fields in the database become unreadable.
DATA_ENCRYPTION_KEY=

# --- RAG ---------------------------------------------------------------------
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3

# --- Features (OFF by default) ----------------------------------------------
MCP_SERVER_ENABLED=false
AUTORESEARCH_ENABLED=false

# --- Channels ----------------------------------------------------------------
# Uncomment and fill in tokens for each channel you want to enable
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_API_TOKEN=
# GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# --- Caddy (production profile only) ----------------------------------------
# CADDY_DOMAIN=localhost       # Set to your domain for auto-TLS

# --- Relay (compute donation) ------------------------------------------------
# RELAY_TOKEN=                 # Auth token for relay connections
# RECLAW_SERVER=ws://backend:8000/ws/relay

# --- Resource Budget ---------------------------------------------------------
RESOURCE_RESERVE_RAM_GB=4
RESOURCE_RESERVE_CPU_PERCENT=30

# --- File Watcher ------------------------------------------------------------
FILE_WATCH_INTERVAL_SECONDS=5
# WATCH_DIR=./data/watch
