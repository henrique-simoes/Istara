{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/tags/tauri-v2.3.1/crates/tauri-cli/schema.json",
  "productName": "Istara",
  "version": "26.126.13",
  "identifier": "com.istara.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../../VERSION",
      "../../.env.example",
      "../../backend/requirements.txt",
      "../../backend/pyproject.toml",
      "../../backend/alembic.ini",
      "../../relay/index.mjs",
      "../../relay/package.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxNjdGNUE2REUyRjFCNzAKUldSd0d5L2VwdlZuOFpLZzZkcDZyb1dieWJVS2dFMXd4MzUvaTdtNzI3MXlmTU4yRFR3L242TjIK",
      "endpoints": [
        "https://github.com/henrique-simoes/Istara/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
